-- Приватный авто-сбор + GUI для Grow a Garden (твой личный)
-- Полная версия с менюшкой

local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local player = Players.LocalPlayer

local autoCollect = false
local collectRadius = 70

-- === ТВОЯ ОРИГИНАЛЬНАЯ ЛОГИКА ===
local function getHarvestPrompt(obj)
    if not obj then return nil end
    return obj:FindFirstChildWhichIsA("ProximityPrompt") or 
           obj:FindFirstChild("Prompt", true)
end

local function isCrop(obj)
    if not obj then return false end
    local name = obj.Name:lower()
    return name:find("plant") or name:find("crop") or name:find("fruit") or 
           name:find("vegetable") or name:find("harvest") or 
           name:find("tree") or name:find("bush")
end

local function collectNearby()
    if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then 
        return 
    end
    
    local rootPos = player.Character.HumanoidRootPart.Position
    
    for _, descendant in ipairs(Workspace:GetDescendants()) do
        if isCrop(descendant) then
            local prompt = getHarvestPrompt(descendant)
            if prompt then
                local part = descendant:FindFirstChildWhichIsA("BasePart") or descendant.PrimaryPart
                if part and (rootPos - part.Position).Magnitude <= collectRadius then
                    prompt.HoldDuration = 0
                    prompt:InputHoldBegin()
                    task.wait(0.08)
                    prompt:InputHoldEnd()
                end
            end
        end
    end
end

-- Главный цикл авто-сбора
task.spawn(function()
    while task.wait(0.35) do
        if autoCollect then
            collectNearby()
        end
    end
end)

